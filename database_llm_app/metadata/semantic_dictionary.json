{
  "metrics": {
    "transaction_amount": {
      "label_ko": "거래금액",
      "expression": "SUM(t.TRNS_AMT)",
      "source_column": "t.TRNS_AMT",
      "default_for": ["ranking", "aggregate", "trend"]
    },
    "contract_quantity": {
      "label_ko": "체결수량",
      "expression": "SUM(t.CNTC_QNTY)",
      "source_column": "t.CNTC_QNTY"
    },
    "transaction_count": {
      "label_ko": "거래건수",
      "expression": "COUNT(*)",
      "source_column": "t.MNGOD_SEQ"
    }
  },
  "dimensions": {
    "fund": {
      "label_ko": "펀드",
      "code_expression": "t.FUND_CODE",
      "label_expression": "f.FUND_NAME",
      "requires_join": "fund"
    },
    "broker": {
      "label_ko": "거래상대방",
      "code_expression": "t.TRPL_CODE",
      "label_expression": "p.TRPL_NAME",
      "requires_join": "broker"
    },
    "item": {
      "label_ko": "종목",
      "code_expression": "t.ITMS_CODE",
      "label_expression": "i.ITMS_NAME",
      "requires_join": "item"
    },
    "proc_date": {
      "label_ko": "처리일자",
      "code_expression": "t.PROC_DATE",
      "label_expression": null,
      "requires_join": null
    }
  },
  "synonyms": {
