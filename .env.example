APP_ENV=dev
APP_NAME=database-llm-app
APP_ENABLE_DEBUG_ENDPOINTS=true
PUBLIC_BASE_URL=

APP_HOST=0.0.0.0
APP_PORT=8010
MCP_PATH=/mcp
MCP_ENABLE_DNS_REBINDING_PROTECTION=false

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5.4-mini

MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=
MSSQL_CHARSET=CP949

# 쉼표로 구분합니다. 비우면 기본 테이블 집합을 사용합니다.
DB_ALLOWED_TABLES=PFO_FTOP_INTG_TR,TRU_FUND_INFR_BS,TRU_FTOP_ITMS_BS,TRU_TRPL_BS
DB_QUERY_ROW_LIMIT=200

